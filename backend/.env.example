# Server Settings
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB Settings
MONGODB_URI=mongodb://localhost:27017/careermantra

# JWT Configuration
JWT_ACCESS_SECRET=your_jwt_access_secret_key_change_me_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# SMTP Configuration (Fallback to Ethereal Sandbox if not configured)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@careermantra.org

# Cloudinary Configuration (Fallback to local /uploads folder if not configured)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
